# Copy this to .env and add your keys

# Required
OPENAI_API_KEY=

# Optional: API authentication (if set, all API requests need a Bearer token)
CLARITY_API_KEY=

# Optional: GitHub token for higher rate limits (60/hr without, 5000/hr with)
CLARITY_GITHUB_TOKEN=

# Optional: NewsAPI key for reliable news fetching
NEWS_API_KEY=

# Optional: Cache TTL in seconds (default: 21600 = 6 hours)
CACHE_TTL_SECONDS=21600
